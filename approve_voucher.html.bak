<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phê duyệt Phiếu</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Roboto', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            max-width: 600px;
            width: 100%;
            padding: 40px;
        }

        h1 {
            color: #34A853;
            margin-bottom: 10px;
            font-size: 28px;
        }

        .subtitle {
            color: #666;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .voucher-info {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 25px;
            border-left: 4px solid #34A853;
        }

        .voucher-info p {
            margin: 8px 0;
            color: #333;
        }

        .voucher-info strong {
            color: #555;
            display: inline-block;
            min-width: 120px;
        }

        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        button {
            flex: 1;
            padding: 14px 24px;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-approve {
            background: #34A853;
            color: white;
        }

        .btn-approve:hover {
            background: #2d8f47;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(52, 168, 83, 0.3);
        }

        .btn-cancel {
            background: #f0f0f0;
            color: #333;
        }

        .btn-cancel:hover {
            background: #e0e0e0;
        }

        .message {
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
        }

        .message.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .message.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .message.show {
            display: block;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }

        .loading.show {
            display: block;
        }

        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #34A853;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 10px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>✅ Phê duyệt Phiếu</h1>
        <p class="subtitle">Xác nhận phê duyệt phiếu này</p>

        <div id="message" class="message"></div>
        <div id="loading" class="loading">
            <div class="spinner"></div>
            <p>Đang xử lý...</p>
        </div>

        <div id="voucher-info" class="voucher-info">
            <!-- Voucher info will be populated from URL params -->
        </div>

        <!-- Signature Upload Section -->
        <div id="signature-section" style="margin: 20px 0; padding: 20px; background: #f8f9fa; border-radius: 8px; border-left: 4px solid #34A853;">
            <h3 style="margin-bottom: 15px; color: #333; font-size: 16px;">✍️ Chữ ký người phê duyệt <span style="color: #EA4335;">*</span></h3>
            <div id="signature-preview" style="margin-bottom: 15px; min-height: 100px; border: 2px dashed #ddd; border-radius: 6px; display: flex; align-items: center; justify-content: center; background: white;">
                <span id="signature-placeholder" style="color: #94a3b8; font-size: 14px;">Chưa có chữ ký</span>
                <img id="signature-img" src="" alt="Chữ ký" style="max-width: 100%; max-height: 150px; display: none; border-radius: 4px;">
            </div>
            <div style="display: flex; gap: 10px;">
                <label for="signature-upload-input" style="flex: 1; padding: 10px 16px; background: #34A853; color: white; border-radius: 6px; cursor: pointer; text-align: center; font-size: 14px; display: inline-block;">
                    📤 Tải lên chữ ký
                </label>
                <input type="file" id="signature-upload-input" accept="image/png,image/jpeg,image/jpg" style="display: none;">
                <button type="button" id="clear-signature-btn" onclick="clearSignature()" style="padding: 10px 16px; background: #f0f0f0; color: #333; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; display: none;">
                    🗑️ Xóa
                </button>
            </div>
            <p id="signature-error" style="color: #EA4335; font-size: 12px; margin-top: 8px; display: none;"></p>
        </div>

        <div class="button-group">
            <button type="button" class="btn-cancel" onclick="window.close()">Hủy</button>
            <button type="button" class="btn-approve" onclick="approveVoucher()" id="approve-btn">Xác nhận phê duyệt</button>
        </div>
    </div>

    <script>
        // Get URL parameters
        const urlParams = new URLSearchParams(window.location.search);
        const voucherNumber = urlParams.get('voucherNumber') || 'N/A';
        const voucherType = urlParams.get('voucherType') || 'N/A';
        const company = urlParams.get('company') || 'N/A';
        const employee = urlParams.get('employee') || 'N/A';
        const amount = urlParams.get('amount') || 'N/A';
        const requestorEmail = urlParams.get('requestorEmail') || '';
        const approverEmail = urlParams.get('approverEmail') || '';

        // Debug: Log all URL parameters
        console.log('=== APPROVE VOUCHER PAGE LOADED ===');
        console.log('Full URL:', window.location.href);
        console.log('URL Parameters:', {
            voucherNumber: voucherNumber,
            voucherType: voucherType,
            company: company,
            employee: employee,
            amount: amount,
            requestorEmail: requestorEmail,
            approverEmail: approverEmail
        });
        console.log('Requestor Email:', requestorEmail);
        console.log('Approver Email:', approverEmail);
        
        if (!requestorEmail || requestorEmail.trim() === '') {
            console.error('❌ ERROR: requestorEmail is empty!');
            console.error('This will cause email approval notification to fail.');
            console.error('Please check the approval link in the email.');
        } else {
            console.log('✅ requestorEmail is valid:', requestorEmail);
        }

        // Populate voucher info
        document.getElementById('voucher-info').innerHTML = `
            <p><strong>Số phiếu:</strong> ${voucherNumber}</p>
            <p><strong>Loại phiếu:</strong> ${voucherType}</p>
            <p><strong>Công ty:</strong> ${company}</p>
            <p><strong>Người đề nghị:</strong> ${employee}</p>
            <p><strong>Tổng số tiền:</strong> ${amount}</p>
            ${requestorEmail ? `<p><strong>Email người đề nghị:</strong> ${requestorEmail}</p>` : '<p style="color: red;"><strong>⚠️ Cảnh báo:</strong> Không tìm thấy email người đề nghị!</p>'}
        `;

        // Use proxy URL to avoid CORS issues
        // For direct URL, use: 'https://script.google.com/macros/s/AKfycbyltkunEjTHhFSRH6evpwDAxZk74QouLTG-FSlCOQtLJGts8guLhFYuBq9n1h0fJvyd/exec'
        const GOOGLE_APPS_SCRIPT_WEB_APP_URL = '/api/voucher';

        // Signature data
        let approverSignatureData = null;

        // Helper function to convert File to base64
        function fileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
                reader.readAsDataURL(file);
            });
        }

        // Compress and resize image signature to reduce payload size
        async function compressImageSignature(file, maxWidth = 800, maxHeight = 400, quality = 0.7) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        // Calculate new dimensions
                        let width = img.width;
                        let height = img.height;
                        
                        if (width > maxWidth || height > maxHeight) {
                            const ratio = Math.min(maxWidth / width, maxHeight / height);
                            width = width * ratio;
                            height = height * ratio;
                        }
                        
                        // Create canvas and resize
                        const canvas = document.createElement('canvas');
                        canvas.width = width;
                        canvas.height = height;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, width, height);
                        
                        // Convert to base64 with compression
                        const base64 = canvas.toDataURL('image/jpeg', quality);
                        console.log(`📏 Signature compressed: ${img.width}x${img.height} -> ${width}x${height}, size: ${(base64.length / 1024).toFixed(2)}KB`);
                        resolve(base64);
                    };
                    img.onerror = () => reject(new Error('Failed to load image'));
                    img.src = e.target.result;
                };
                reader.onerror = () => reject(new Error('Failed to read file'));
                reader.readAsDataURL(file);
            });
        }

        // ============ SIGNATURE VERIFICATION FUNCTIONS ============
        let companyApproversData = null;
        let currentApproverRole = null;

        // Fetch company approvers data on page load
        async function fetchCompanyApprovers() {
            try {
                console.log('🔍 Fetching company approvers for:', company);
                const response = await fetch(GOOGLE_APPS_SCRIPT_WEB_APP_URL + '?action=getCompanyApprovers&company=' + encodeURIComponent(company));

                // CRITICAL FIX: Check HTTP response status
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                const result = await response.json();

                if (result.success && result.data) {
                    companyApproversData = result.data.approvers;
                    console.log('✅ Company approvers loaded:', companyApproversData);

                    // Determine approver role based on email
                    if (companyApproversData) {
                        if (companyApproversData.accountant && companyApproversData.accountant.email === approverEmail) {
                            currentApproverRole = 'accountant';
                        } else if (companyApproversData.legalRep && companyApproversData.legalRep.email === approverEmail) {
                            currentApproverRole = 'legalRep';
                        } else if (companyApproversData.treasurer && companyApproversData.treasurer.email === approverEmail) {
                            currentApproverRole = 'treasurer';
                        }
                        console.log('👤 Detected approver role:', currentApproverRole);
                    }
                } else {
                    // CRITICAL FIX: Throw error instead of silent warning
                    throw new Error(result.message || 'Failed to load company approvers');
                }
            } catch (error) {
                // CRITICAL FIX: Show user-facing error alert
                console.error('❌ Error fetching company approvers:', error);
                showMessage(
                    `❌ LỖI: Không thể tải thông tin công ty\n\n` +
                    `Không thể kết nối đến hệ thống để lấy danh sách người phê duyệt.\n\n` +
                    `Chi tiết: ${error.message}\n\n` +
                    `Vui lòng:\n` +
                    `1. Kiểm tra kết nối mạng\n` +
                    `2. Tải lại trang\n` +
                    `3. Liên hệ quản trị viên nếu vẫn lỗi`,
                    'error'
                );
                throw error; // Propagate error to caller
            }
        }

        // Fetch sample signature from URL via backend proxy
        async function fetchSampleSignature(signatureUrl) {
            if (!signatureUrl || signatureUrl.trim() === '') {
                console.log('🔍 No sample signature URL provided');
                return null;
            }
            try {
                console.log('🖼️ Fetching sample signature from:', signatureUrl);
                console.log('📡 Backend URL:', GOOGLE_APPS_SCRIPT_WEB_APP_URL);

                const formData = new FormData();
                formData.append('data', JSON.stringify({
                    action: 'fetchSignatureImage',
                    imageUrl: signatureUrl
                }));

                const response = await fetch(GOOGLE_APPS_SCRIPT_WEB_APP_URL, {
                    method: 'POST',
                    body: formData
                });

                console.log('📥 Response status:', response.status, response.statusText);

                if (!response.ok) {
                    console.error('❌ HTTP error:', response.status, response.statusText);
                    const errorText = await response.text();
                    console.error('❌ Response body:', errorText);
                    return null;
                }

                const result = await response.json();
                console.log('📦 Backend response:', result);

                if (result.success && result.data && result.data.imageBase64) {
                    console.log('✅ Sample signature fetched successfully, size:', result.data.imageBase64.length);
                    return result.data.imageBase64;
                } else {
                    console.error('❌ Backend returned failure:', {
                        success: result.success,
                        message: result.message,
                        hasData: !!result.data,
                        hasImageBase64: !!(result.data && result.data.imageBase64)
                    });
                    return null;
                }
            } catch (error) {
                console.error('❌ Exception fetching sample signature:', error);
                console.error('❌ Error details:', {
                    name: error.name,
                    message: error.message,
                    stack: error.stack
                });
                return null;
            }
        }

        // Generate perceptual hash for image comparison
        async function generateImageHash(base64Data) {
            return new Promise((resolve) => {
                const img = new Image();
                img.crossOrigin = 'anonymous';
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    const size = 8;
                    canvas.width = size;
                    canvas.height = size;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, size, size);
                    
                    const imageData = ctx.getImageData(0, 0, size, size);
                    const pixels = imageData.data;
                    
                    let totalGray = 0;
                    const grayValues = [];
                    for (let i = 0; i < pixels.length; i += 4) {
                        const gray = pixels[i] * 0.299 + pixels[i + 1] * 0.587 + pixels[i + 2] * 0.114;
                        grayValues.push(gray);
                        totalGray += gray;
                    }
                    
                    const avgGray = totalGray / grayValues.length;
                    const hash = grayValues.map(g => g >= avgGray ? '1' : '0').join('');
                    
                    resolve(hash);
                };
                img.onerror = () => resolve(null);
                img.src = base64Data;
            });
        }

        // Compare uploaded signature with sample signature
        async function compareSignatures(uploadedBase64, sampleUrl) {
            try {
                const sampleBase64 = await fetchSampleSignature(sampleUrl);

                // CRITICAL FIX: Fail-closed instead of fail-open
                if (!sampleBase64) {
                    console.error('❌ Failed to fetch sample signature');
                    return {
                        verified: false,
                        reason: 'fetch_failed',
                        similarity: 0,
                        threshold: 75
                    };
                }

                console.log('🔍 Generating hashes for comparison...');
                const uploadedHash = await generateImageHash(uploadedBase64);
                const sampleHash = await generateImageHash(sampleBase64);

                // CRITICAL FIX: Check if hash generation succeeded
                if (!uploadedHash || !sampleHash) {
                    console.error('❌ Hash generation failed');
                    return {
                        verified: false,
                        reason: 'hash_failed',
                        similarity: 0,
                        threshold: 75
                    };
                }

                // Calculate Hamming distance
                let differences = 0;
                for (let i = 0; i < uploadedHash.length; i++) {
                    if (uploadedHash[i] !== sampleHash[i]) differences++;
                }

                const similarity = ((uploadedHash.length - differences) / uploadedHash.length) * 100;
                const SIMILARITY_THRESHOLD = 75; // Adjusted threshold for signature verification

                console.log(`🔍 Signature similarity: ${similarity.toFixed(2)}% (threshold: ${SIMILARITY_THRESHOLD}%)`);

                if (similarity >= SIMILARITY_THRESHOLD) {
                    console.log('✅ Signature VERIFIED');
                    return {
                        verified: true,
                        similarity: similarity.toFixed(2),
                        reason: 'match',
                        threshold: SIMILARITY_THRESHOLD
                    };
                } else {
                    console.log('❌ Signature MISMATCH');
                    return {
                        verified: false,
                        similarity: similarity.toFixed(2),
                        reason: 'mismatch',
                        threshold: SIMILARITY_THRESHOLD
                    };
                }
            } catch (error) {
                // CRITICAL FIX: Fail-closed on any error
                console.error('❌ Signature comparison error:', error);
                return {
                    verified: false,
                    reason: 'comparison_error',
                    similarity: 0,
                    threshold: 75,
                    error: error.message
                };
            }
        }

        // Initialize: Fetch company approvers when page loads
        fetchCompanyApprovers();

        // Handle signature upload
        document.getElementById('signature-upload-input').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            
            const errorDiv = document.getElementById('signature-error');
            errorDiv.style.display = 'none';
            
            // Validate file type
            if (!file.type.match(/^image\/(png|jpeg|jpg)$/)) {
                errorDiv.textContent = 'Chỉ hỗ trợ file PNG, JPG, JPEG';
                errorDiv.style.display = 'block';
                e.target.value = '';
                return;
            }
            
            // Validate file size (max 2MB)
            if (file.size > 2 * 1024 * 1024) {
                errorDiv.textContent = 'File quá lớn. Tối đa 2MB';
                errorDiv.style.display = 'block';
                e.target.value = '';
                return;
            }
            
            try {
                // Compress image before converting to base64 to reduce payload size
                approverSignatureData = await compressImageSignature(file, 800, 400, 0.7);
                
                // Check if compressed signature is still too large (max 500KB for signature)
                if (approverSignatureData.length > 500 * 1024) {
                    errorDiv.textContent = 'Chữ ký vẫn quá lớn sau khi nén. Vui lòng chọn ảnh nhỏ hơn.';
                    errorDiv.style.display = 'block';
                    e.target.value = '';
                    return;
                }
                
                // Update preview
                const placeholder = document.getElementById('signature-placeholder');
                const img = document.getElementById('signature-img');
                const clearBtn = document.getElementById('clear-signature-btn');
                
                placeholder.style.display = 'none';
                img.src = approverSignatureData;
                img.style.display = 'block';
                clearBtn.style.display = 'block';
                
                console.log('✅ Signature uploaded and compressed successfully, size: ' + (approverSignatureData.length / 1024).toFixed(2) + 'KB');
            } catch (error) {
                errorDiv.textContent = 'Lỗi tải file: ' + error.message;
                errorDiv.style.display = 'block';
                e.target.value = '';
            }
        });

        // Clear signature
        function clearSignature() {
            approverSignatureData = null;
            const placeholder = document.getElementById('signature-placeholder');
            const img = document.getElementById('signature-img');
            const clearBtn = document.getElementById('clear-signature-btn');
            const input = document.getElementById('signature-upload-input');
            
            placeholder.style.display = 'block';
            img.style.display = 'none';
            clearBtn.style.display = 'none';
            input.value = '';
        }

        // Approve voucher
        async function approveVoucher() {
            // Validate requestor email
            if (!requestorEmail || requestorEmail.trim() === '') {
                showMessage('Lỗi: Không tìm thấy email người đề nghị. Vui lòng kiểm tra lại link phê duyệt.', 'error');
                return;
            }

            // Validate signature is uploaded
            if (!approverSignatureData) {
                const errorDiv = document.getElementById('signature-error');
                errorDiv.textContent = 'Vui lòng tải lên chữ ký trước khi phê duyệt';
                errorDiv.style.display = 'block';
                
                // Scroll to signature section
                document.getElementById('signature-section').scrollIntoView({ behavior: 'smooth', block: 'center' });
                return;
            }

            // Show loading
            document.getElementById('loading').classList.add('show');
            document.querySelector('.button-group').style.display = 'none';
            document.getElementById('approve-btn').disabled = true;

            // Debug logs
            console.log('=== APPROVING VOUCHER ===');
            console.log('Voucher Number:', voucherNumber);
            console.log('Requestor Email:', requestorEmail);
            console.log('Approver Email:', approverEmail);
            console.log('Signature uploaded:', !!approverSignatureData);
            console.log('Approver role:', currentApproverRole);

            try {
                // ============ MANDATORY SIGNATURE VERIFICATION ============
                let sampleSignatureUrl = null;
                // CRITICAL FIX: Default to fail-closed (verified: false)
                let verificationResult = { verified: false, reason: 'no_sample_required', similarity: '0' };

                // Get sample signature URL based on approver role
                if (companyApproversData && currentApproverRole) {
                    if (currentApproverRole === 'accountant' && companyApproversData.accountant) {
                        sampleSignatureUrl = companyApproversData.accountant.signature;
                    } else if (currentApproverRole === 'legalRep' && companyApproversData.legalRep) {
                        sampleSignatureUrl = companyApproversData.legalRep.signature;
                    } else if (currentApproverRole === 'treasurer' && companyApproversData.treasurer) {
                        sampleSignatureUrl = companyApproversData.treasurer.signature;
                    }
                }

                // CRITICAL FIX: Block approval if sample signature missing
                if (!sampleSignatureUrl || sampleSignatureUrl.trim() === '') {
                    console.error('❌ No sample signature URL found for this approver');
                    showMessage(
                        `❌ KHÔNG THỂ PHÊ DUYỆT: Thiếu chữ ký mẫu\n\n` +
                        `Vui lòng liên hệ quản trị viên để cập nhật chữ ký mẫu cho người phê duyệt này trong hệ thống.\n\n` +
                        `Không thể phê duyệt phiếu khi chưa có chữ ký mẫu để so sánh.`,
                        'error'
                    );
                    document.getElementById('loading').classList.remove('show');
                    document.querySelector('.button-group').style.display = 'flex';
                    document.getElementById('approve-btn').disabled = false;
                    return; // Block approval
                }

                // Perform signature verification
                console.log('🔍 Verifying signature against sample...');
                verificationResult = await compareSignatures(approverSignatureData, sampleSignatureUrl);
                console.log('🔍 Verification result:', verificationResult);

                // MANDATORY: Block approval if verification failed for any reason
                if (!verificationResult.verified) {
                    let errorMessage = '';
                    if (verificationResult.reason === 'mismatch') {
                        errorMessage = `❌ KHÔNG THỂ PHÊ DUYỆT: Chữ ký không khớp!\n` +
                            `Độ tương đồng: ${verificationResult.similarity}%\n` +
                            `(yêu cầu: ${verificationResult.threshold}%)\n\n` +
                            `Vui lòng sử dụng chữ ký mẫu đã đăng ký.`;
                    } else if (verificationResult.reason === 'no_sample' || verificationResult.reason === 'fetch_failed') {
                        errorMessage = `❌ KHÔNG THỂ PHÊ DUYỆT: Lỗi hệ thống\n\n` +
                            `Không thể tải chữ ký mẫu từ hệ thống.\n` +
                            `Lý do: ${verificationResult.reason}\n\n` +
                            `Vui lòng thử lại hoặc liên hệ quản trị viên.`;
                    } else if (verificationResult.reason === 'hash_failed') {
                        errorMessage = `❌ KHÔNG THỂ PHÊ DUYỆT: Lỗi xử lý chữ ký\n\n` +
                            `Không thể xử lý file chữ ký. Vui lòng kiểm tra:\n` +
                            `- File có đúng định dạng PNG/JPG\n` +
                            `- File không bị hỏng\n` +
                            `- Kích thước file hợp lệ\n\n` +
                            `Nếu vẫn lỗi, vui lòng liên hệ quản trị viên.`;
                    } else {
                        errorMessage = `❌ KHÔNG THỂ PHÊ DUYỆT: Lỗi xác thực chữ ký\n\n` +
                            `Lý do: ${verificationResult.reason || 'unknown'}\n\n` +
                            `Vui lòng thử lại hoặc liên hệ quản trị viên.`;
                    }

                    showMessage(errorMessage, 'error');
                    console.log('❌ Approval BLOCKED:', verificationResult.reason);
                    document.getElementById('loading').classList.remove('show');
                    document.querySelector('.button-group').style.display = 'flex';
                    document.getElementById('approve-btn').disabled = false;
                    return; // Block approval
                }
                console.log('✅ Signature verification passed');
                // ============ END SIGNATURE VERIFICATION ============

                // Use POST method to send signature (too large for URL)
                const requestData = {
                    action: 'approveVoucher',
                    voucher: {
                        voucherNumber: voucherNumber,
                        voucherType: voucherType,
                        company: company,
                        employee: employee,
                        amount: amount,
                        requestorEmail: requestorEmail,
                        approverEmail: approverEmail,
                        approvedBy: approverEmail,
                        approverRole: currentApproverRole,
                        approverSignature: approverSignatureData,
                        signatureVerification: verificationResult
                    }
                };

                // Use FormData to avoid CORS preflight issues
                const formData = new FormData();
                formData.append('data', JSON.stringify(requestData));

                const url = GOOGLE_APPS_SCRIPT_WEB_APP_URL;
                
                console.log('=== SENDING APPROVAL REQUEST ===');
                console.log('URL:', url);
                console.log('Requestor Email:', requestorEmail);
                console.log('Approver Email:', approverEmail);

                const response = await fetch(url, {
                    method: 'POST',
                    mode: 'cors',
                    redirect: 'follow',
                    body: formData
                });

                console.log('Response status:', response.status);
                console.log('Response ok:', response.ok);
                
                // Check if response is ok before parsing
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('❌ HTTP Error:', response.status, response.statusText);
                    console.error('❌ Error response body:', errorText.substring(0, 500));
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                
                // Read response text first to check format
                const responseText = await response.text();
                console.log('Response text (first 200 chars):', responseText.substring(0, 200));
                
                // Check if response is HTML (error page)
                if (responseText.trim().toLowerCase().startsWith('<!doctype') || responseText.trim().toLowerCase().startsWith('<html')) {
                    console.error('❌ Response is HTML (error page), not JSON');
                    console.error('Full HTML response:', responseText.substring(0, 1000));
                    throw new Error('Backend trả về trang lỗi HTML thay vì JSON. Có thể URL backend không đúng hoặc có lỗi server.');
                }
                
                let result;
                try {
                    result = JSON.parse(responseText);
                    console.log('Response data:', result);
                } catch (parseError) {
                    console.error('❌ Failed to parse response as JSON:', parseError);
                    console.error('❌ Response was:', responseText.substring(0, 500));
                    throw new Error(`Invalid JSON response: ${parseError.message}`);
                }
                
                if (result.success) {
                    showMessage('Đã phê duyệt phiếu thành công! Email thông báo đã được gửi đến ' + requestorEmail + '.', 'success');
                    
                    // Close window after 3 seconds
                    setTimeout(() => {
                        window.close();
                    }, 3000);
                } else {
                    // Show error message from backend
                    const errorMsg = result.message || 'Có lỗi xảy ra khi phê duyệt';
                    
                    // Check for already processed error
                    if (errorMsg.includes('already processed') || errorMsg.includes('đã được xử lý') || errorMsg.includes('đã duyệt') || errorMsg.includes('đã từ chối')) {
                        showMessage('⚠️ Phiếu này đã được xử lý trước đó. Không thể phê duyệt lại.', 'error');
                    } else {
                        showMessage('Lỗi: ' + errorMsg, 'error');
                    }
                    
                    document.getElementById('loading').classList.remove('show');
                    document.querySelector('.button-group').style.display = 'flex';
                    document.getElementById('approve-btn').disabled = false;
                }

            } catch (error) {
                console.error('Error approving voucher:', error);
                showMessage('Có lỗi xảy ra: ' + error.message + '. Vui lòng kiểm tra Google Apps Script logs hoặc liên hệ IT support.', 'error');
                document.getElementById('loading').classList.remove('show');
                document.querySelector('.button-group').style.display = 'flex';
                document.getElementById('approve-btn').disabled = false;
            }
        }

        function showMessage(message, type) {
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = message;
            messageDiv.className = `message ${type} show`;
            
            // Hide loading
            document.getElementById('loading').classList.remove('show');
        }
    </script>
</body>
</html>

