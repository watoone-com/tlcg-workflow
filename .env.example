# =============================================================================
# TLCG Workflow — copy to `.env` and fill in values (`.env` is git-ignored).
# Mirror the same keys in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# Server-only Apps Script web app URLs (/exec from Deploy → Web app).
VOUCHER_BACKEND_URL=""
PAYMENT_REQUEST_BACKEND_URL=""
TLCGROUP_BACKEND_URL=""

# Browser-facing (also returned by GET /api/config — restrict in GCP Console).
GOOGLE_CLIENT_ID=""
GOOGLE_API_KEY=""

# Drive folder IDs (returned by /api/config).
DRIVE_VOUCHER_FOLDER_ID=""
PURCHASE_REQUEST_FOLDER_ID=""
ACCEPTANCE_MINUTES_FOLDER_ID=""
PAYMENT_REQUEST_FOLDER_ID=""

# Master spreadsheet (returned by /api/config).
MASTER_SPREADSHEET_ID=""
