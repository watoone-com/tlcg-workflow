# =============================================================================
# TLCG Workflow - Vercel Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in actual values.
# .env.local is git-ignored (see .gitignore) so secrets stay off the repo.
#
# After editing locally, sync to Vercel project settings:
#   vercel env add <KEY>          # interactive, per-environment
#   vercel env pull .env.local    # pull from Vercel back to local
#
# These values are read at runtime by:
#   - api/voucher.js   (proxy to Apps Script web apps)
#   - api/config.js    (frontend-safe config exposed to HTML pages)
#
# NOTE: Apps Script (.gs files) does NOT read this file. Mirror these values
# in each Apps Script project's "Project Settings -> Script properties".
# See SCRIPT_PROPERTIES.md for the per-project mapping.
# =============================================================================

# ----- Apps Script web-app deployment URLs (server-only, never exposed) ------
# Production /exec URLs from Apps Script Deploy -> New deployment -> Web app.
PHIEU_THU_CHI_BACKEND_URL="https://script.google.com/macros/s/REPLACE_ME/exec"
PAYMENT_REQUEST_BACKEND_URL="https://script.google.com/macros/s/REPLACE_ME/exec"
TLCGROUP_BACKEND_URL="https://script.google.com/macros/s/REPLACE_ME/exec"

# ----- Google OAuth client (frontend, exposed via /api/config) ---------------
# Used by GIS (Google Identity Services) for client-side Drive uploads.
# MUST be domain-restricted in GCP Console (Authorized JavaScript origins).
GOOGLE_CLIENT_ID="REPLACE_ME.apps.googleusercontent.com"
# MUST be HTTP-referrer-restricted in GCP Console.
GOOGLE_API_KEY="REPLACE_ME"

# ----- Google Drive folder IDs (frontend, exposed via /api/config) -----------
# Folder where Voucher (phieu_thu_chi) attachments land.
DRIVE_VOUCHER_FOLDER_ID="REPLACE_ME"
# DRAFT parent for new Payment Request folders (created on "Tao folder").
PAY_DRAFT_PARENT_FOLDER_ID="REPLACE_ME"
# FINAL parent. Folder is moved here on successful submit.
PAY_FINAL_PARENT_FOLDER_ID="REPLACE_ME"

# ----- Google Sheets (frontend, exposed via /api/config) ---------------------
# Master spreadsheet ID used by Voucher / Payment Request / Login backends.
MASTER_SPREADSHEET_ID="REPLACE_ME"
